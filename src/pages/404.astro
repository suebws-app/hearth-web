---
import Layout from "../layouts/Layout.astro";
import { flattenMessages } from "../utils/flattenMessages";
import NotFoundPage from "../components/NotFoundPage";

const localeModules = import.meta.glob<{ default: Record<string, unknown> }>(
  "../locales/*.json",
  { eager: true },
);

const allMessages: Record<string, Record<string, string>> = {};
for (const [path, mod] of Object.entries(localeModules)) {
  const match = path.match(/\/([a-z-]+)\.json$/);
  if (match && mod?.default) {
    allMessages[match[1]] = flattenMessages(mod.default);
  }
}

const enMessages = allMessages["en"] ?? {};
const title = enMessages["notfound.header"] ?? "Page not found";
const description = enMessages["notfound.description"] ?? "";
---

<Layout title={title} description={description} lang="en" path="/404/" noindex>
  <NotFoundPage client:idle allMessages={allMessages} />
</Layout>
