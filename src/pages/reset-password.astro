---
import Layout from "../layouts/Layout.astro";
import ResetPasswordWithI18n from "../components/ResetPasswordWithI18n";
import { flattenMessages } from "../utils/flattenMessages";

const localeModules = import.meta.glob<{ default: Record<string, unknown> }>(
  "../locales/*.json",
  { eager: true }
);

const allMessages: Record<string, Record<string, string>> = {};
for (const [path, mod] of Object.entries(localeModules)) {
  const match = path.match(/\/([a-z-]+)\.json$/);
  if (match && mod?.default) {
    allMessages[match[1]] = flattenMessages(mod.default);
  }
}

const enMessages = allMessages["en"] ?? {};
---

<Layout
  title={enMessages["reset_password.page_title"] ?? "Reset Password"}
  description={enMessages["reset_password.page_description"] ?? "Reset your Hearth account password"}
  lang="en"
  path="/reset-password"
  noindex={true}
>
  <main class="bg-background text-foreground w-screen font-body" role="main">
    <ResetPasswordWithI18n client:load allMessages={allMessages} />
  </main>
</Layout>
