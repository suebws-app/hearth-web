---
import IconSun from "@/assets/icons/sun";
import IconMoon from "@/assets/icons/moon";
---

<button
  type="button"
  id="theme-toggle"
  class="focus:ring-primary/50 rounded-lg p-2 text-muted-foreground transition-colors hover:text-foreground focus:outline-none focus:ring-2"
  aria-label="Toggle theme"
>
  <IconSun className="h-5 w-5 hidden [html[data-theme='dark']_&]:inline" />
  <IconMoon className="h-5 w-5 inline [html[data-theme='dark']_&]:hidden" />
</button>

<script is:inline>
  (function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    function label() {
      var isDark = document.documentElement.getAttribute("data-theme") === "dark";
      btn.setAttribute(
        "aria-label",
        isDark ? "Switch to light mode" : "Switch to dark mode",
      );
    }
    label();
    btn.addEventListener("click", function () {
      var current = document.documentElement.getAttribute("data-theme");
      var next = current === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try {
        window.localStorage.setItem("theme", next);
      } catch (e) {}
      label();
    });
  })();
</script>
